## 2. DATABASE SCHEMA (PostgreSQL)

```sql
-- CORE ENTITIES

CREATE TABLE companies (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) NOT NULL,
    website VARCHAR(500),
    country VARCHAR(100),
    city VARCHAR(100),
    category VARCHAR(100),  -- 'agency', 'studio', 'startup', 'brand', 'production_house', 'platform'
    subcategory VARCHAR(100),  -- '3d_cgi', 'dooh', 'creative_agency', 'real_estate', etc.
    size_range VARCHAR(50),  -- '1-10', '11-50', '51-200', '200+'
    founded_year INT,
    linkedin_url VARCHAR(500),
    clutch_url VARCHAR(500),
    industry VARCHAR(200),
    funding_stage VARCHAR(50),  -- 'bootstrapped', 'seed', 'series_a', etc.
    funding_amount DECIMAL(12,2),
    tech_stack TEXT[],  -- array of technologies they use
    services_offered TEXT[],
    services_needed TEXT[],  -- what they might outsource
    source VARCHAR(100),  -- how we found them: 'clutch', 'linkedin', 'google', 'manual'
    source_url VARCHAR(500),
    demand_signal VARCHAR(200),  -- 'job_post', 'funding', 'expansion', 'bad_content', etc.
    demand_signal_date TIMESTAMP,
    priority CHAR(1) DEFAULT 'C',  -- A, B, C
    lead_score INT DEFAULT 0,  -- 0-100 AI-calculated
    tags TEXT[],
    notes TEXT,
    is_archived BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE contacts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    company_id UUID REFERENCES companies(id) ON DELETE CASCADE,
    first_name VARCHAR(100),
    last_name VARCHAR(100),
    title VARCHAR(200),
    email VARCHAR(300),
    email_verified BOOLEAN DEFAULT FALSE,
    linkedin_url VARCHAR(500),
    phone VARCHAR(50),
    is_decision_maker BOOLEAN DEFAULT FALSE,
    role_type VARCHAR(50),  -- 'creative_director', 'producer', 'founder', 'marketing_lead'
    preferred_channel VARCHAR(50),  -- 'email', 'linkedin', 'phone'
    timezone VARCHAR(50),
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- PIPELINE / CRM

CREATE TABLE pipeline_stages (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    position INT NOT NULL,
    color VARCHAR(7) DEFAULT '#6C5CE7'
);

-- Default stages: New Lead → Researched → Contacted → Responded → Meeting → Proposal Sent → Negotiating → Won → Lost → Nurture

CREATE TABLE deals (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    company_id UUID REFERENCES companies(id),
    contact_id UUID REFERENCES contacts(id),
    stage_id INT REFERENCES pipeline_stages(id),
    title VARCHAR(300),
    service_type VARCHAR(100),  -- '3d_animation', 'dooh', 'product_viz', 'web_dev', etc.
    estimated_value DECIMAL(10,2),
    currency VARCHAR(3) DEFAULT 'USD',
    probability INT DEFAULT 10,  -- 0-100%
    expected_close_date DATE,
    actual_close_date DATE,
    lost_reason TEXT,
    won_amount DECIMAL(10,2),
    source_channel VARCHAR(50),  -- 'upwork', 'linkedin_dm', 'cold_email', 'referral', 'inbound'
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- OUTREACH ENGINE

CREATE TABLE outreach_templates (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(200) NOT NULL,
    channel VARCHAR(50) NOT NULL,  -- 'email', 'linkedin_dm', 'upwork_proposal', 'twitter_dm'
    category VARCHAR(100),  -- 'cold_studio', 'cold_dooh', 'cold_startup', 'follow_up_1', etc.
    subject_line TEXT,
    body TEXT NOT NULL,
    variables TEXT[],  -- ['{{company_name}}', '{{contact_name}}', '{{specific_project}}', ...]
    tags TEXT[],
    usage_count INT DEFAULT 0,
    response_rate DECIMAL(5,2),  -- calculated: responses / sends
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE outreach_sequences (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(200) NOT NULL,
    description TEXT,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE sequence_steps (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    sequence_id UUID REFERENCES outreach_sequences(id) ON DELETE CASCADE,
    step_number INT NOT NULL,
    template_id UUID REFERENCES outreach_templates(id),
    delay_days INT NOT NULL,  -- days after previous step
    channel VARCHAR(50),
    condition VARCHAR(100),  -- 'no_response', 'opened_not_replied', 'always'
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE outreach_messages (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    deal_id UUID REFERENCES deals(id),
    contact_id UUID REFERENCES contacts(id),
    company_id UUID REFERENCES companies(id),
    template_id UUID REFERENCES outreach_templates(id),
    sequence_id UUID REFERENCES outreach_sequences(id),
    step_number INT,
    channel VARCHAR(50) NOT NULL,
    subject TEXT,
    body TEXT NOT NULL,
    rendered_body TEXT,  -- after variable substitution
    status VARCHAR(50) DEFAULT 'draft',  -- 'draft', 'scheduled', 'sent', 'delivered', 'opened', 'clicked', 'replied', 'bounced'
    scheduled_at TIMESTAMP,
    sent_at TIMESTAMP,
    opened_at TIMESTAMP,
    replied_at TIMESTAMP,
    tracking_id VARCHAR(100),  -- for email open/click tracking
    ai_personalization_used BOOLEAN DEFAULT FALSE,
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW()
);

-- SCRAPING ENGINE (extend existing)

CREATE TABLE scrape_jobs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    query_id UUID,  -- links to saved queries
    platform VARCHAR(50),  -- 'linkedin', 'google', 'clutch', 'upwork', etc.
    query_text TEXT,
    status VARCHAR(50) DEFAULT 'pending',  -- 'pending', 'running', 'completed', 'failed'
    results_count INT DEFAULT 0,
    new_companies_found INT DEFAULT 0,
    error_message TEXT,
    started_at TIMESTAMP,
    completed_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE saved_queries (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(200),
    platform VARCHAR(50),
    query_text TEXT,
    query_type VARCHAR(50),  -- 'people', 'companies', 'jobs', 'posts'
    category VARCHAR(100),
    frequency VARCHAR(20),  -- 'daily', 'weekly', 'monthly'
    last_run_at TIMESTAMP,
    next_run_at TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE,
    auto_run BOOLEAN DEFAULT FALSE,
    results_count INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW()
);

-- INTELLIGENCE FEED

CREATE TABLE intel_feed (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    source VARCHAR(100),  -- 'google_alert', 'scraper', 'manual', 'rss', 'social_monitor'
    title VARCHAR(500),
    content TEXT,
    url VARCHAR(1000),
    company_id UUID REFERENCES companies(id),  -- optional link
    signal_type VARCHAR(100),  -- 'funding', 'hiring', 'expansion', 'new_campaign', 'competitor_move', 'award'
    relevance_score INT,  -- AI-calculated 0-100
    is_read BOOLEAN DEFAULT FALSE,
    is_actionable BOOLEAN DEFAULT FALSE,
    action_taken TEXT,
    published_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW()
);

-- FINANCIAL TRACKING

CREATE TABLE invoices (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    deal_id UUID REFERENCES deals(id),
    company_id UUID REFERENCES companies(id),
    invoice_number VARCHAR(50) UNIQUE,
    amount DECIMAL(10,2),
    currency VARCHAR(3) DEFAULT 'USD',
    tax_amount DECIMAL(10,2) DEFAULT 0,
    total_amount DECIMAL(10,2),
    status VARCHAR(50) DEFAULT 'draft',  -- 'draft', 'sent', 'viewed', 'paid', 'overdue', 'cancelled'
    issued_date DATE,
    due_date DATE,
    paid_date DATE,
    payment_method VARCHAR(50),  -- 'bank_transfer', 'paypal', 'stripe', 'wise'
    description TEXT,
    line_items JSONB,  -- [{description, quantity, rate, amount}]
    pdf_path VARCHAR(500),
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE expenses (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    category VARCHAR(100),  -- 'software', 'hardware', 'marketing', 'travel', 'education'
    description TEXT,
    amount DECIMAL(10,2),
    currency VARCHAR(3) DEFAULT 'USD',
    date DATE,
    is_recurring BOOLEAN DEFAULT FALSE,
    recurring_frequency VARCHAR(20),
    receipt_path VARCHAR(500),
    created_at TIMESTAMP DEFAULT NOW()
);

-- TASKS / DAILY PLAYBOOK

CREATE TABLE tasks (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title VARCHAR(300) NOT NULL,
    description TEXT,
    task_type VARCHAR(50),  -- 'outreach', 'follow_up', 'research', 'content', 'admin', 'proposal'
    related_deal_id UUID REFERENCES deals(id),
    related_company_id UUID REFERENCES companies(id),
    related_contact_id UUID REFERENCES contacts(id),
    priority VARCHAR(10) DEFAULT 'medium',  -- 'critical', 'high', 'medium', 'low'
    status VARCHAR(50) DEFAULT 'todo',  -- 'todo', 'in_progress', 'done', 'skipped'
    due_date DATE,
    due_time TIME,
    completed_at TIMESTAMP,
    is_recurring BOOLEAN DEFAULT FALSE,
    recurrence_rule VARCHAR(100),  -- 'daily', 'weekdays', 'weekly:mon,wed,fri', etc.
    auto_generated BOOLEAN DEFAULT FALSE,  -- system-created follow-up tasks
    created_at TIMESTAMP DEFAULT NOW()
);

-- ACTIVITY LOG (everything that happens)

CREATE TABLE activity_log (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    actor VARCHAR(50) DEFAULT 'user',  -- 'user', 'system', 'ai', 'scraper'
    action VARCHAR(100) NOT NULL,  -- 'sent_email', 'moved_deal', 'added_company', 'scored_lead', etc.
    entity_type VARCHAR(50),  -- 'company', 'contact', 'deal', 'message', 'task'
    entity_id UUID,
    metadata JSONB,  -- flexible data about the action
    created_at TIMESTAMP DEFAULT NOW()
);

-- PORTFOLIO / CASE STUDIES

CREATE TABLE portfolio_items (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title VARCHAR(300),
    client_name VARCHAR(200),
    service_type VARCHAR(100),
    description TEXT,
    thumbnail_path VARCHAR(500),
    media_urls TEXT[],  -- links to videos, images
    tags TEXT[],
    is_public BOOLEAN DEFAULT TRUE,
    display_order INT,
    created_at TIMESTAMP DEFAULT NOW()
);

-- ANALYTICS SNAPSHOTS (pre-computed daily)

CREATE TABLE daily_metrics (
    id SERIAL PRIMARY KEY,
    date DATE UNIQUE NOT NULL,
    new_companies_added INT DEFAULT 0,
    outreach_sent INT DEFAULT 0,
    responses_received INT DEFAULT 0,
    meetings_booked INT DEFAULT 0,
    proposals_sent INT DEFAULT 0,
    deals_won INT DEFAULT 0,
    revenue_closed DECIMAL(10,2) DEFAULT 0,
    pipeline_value DECIMAL(10,2) DEFAULT 0,
    response_rate DECIMAL(5,2),
    tasks_completed INT DEFAULT 0,
    tasks_total INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW()
);
```

